/**
 * Potomac Integrated Asset System - Phase 3 Complete
 * Combines dynamic tables, visual elements, and templates into unified system
 * 
 * This system integrates all converted Adobe Illustrator assets with the
 * existing template system for comprehensive presentation generation.
 */

const { PotomacSlideTemplates } = require('../templates/slide-templates.js');
const { PotomacDynamicTables } = require('../data-tables/dynamic-tables.js');
const { PotomacVisualElements } = require('../infographics/visual-elements.js');
const { POTOMAC_COLORS } = require('../brand-assets/colors/potomac-colors.js');
const { POTOMAC_FONTS } = require('../brand-assets/fonts/potomac-fonts.js');  // FIX: was missing

// Strip leading '#' from brand colors (pptxgenjs does not want the '#' prefix)
function _c(hex) { return hex ? String(hex).replace('#', '') : 'FEC00F'; }

class PotomacIntegratedAssets {
  constructor(pptxGenerator, options = {}) {
    this.pptx = pptxGenerator;
    this.options = options;
    
    // Initialize all asset systems
    this.templates = new PotomacSlideTemplates(pptxGenerator, options);
    this.tables = new PotomacDynamicTables(pptxGenerator, options);
    this.visuals = new PotomacVisualElements(pptxGenerator, options);
    
    // Asset registry for smart selection
    this.assetRegistry = this.initializeAssetRegistry();
  }

  initializeAssetRegistry() {
    return {
      // Data table assets (converted from Adobe Illustrator)
      dataTables: {
        'passive-active': {
          method: 'createPassiveActiveTable',
          description: 'Passive vs Active performance comparison',
          requiredData: ['timeframes', 'passive', 'active', 'outperformance'],
          triggers: ['passive', 'active', 'performance comparison', 'vs', 'versus']
        },
        'afg-table': {
          method: 'createAFGTable',
          description: 'Asset Fee Grid structure',
          requiredData: ['assetRanges', 'managementFees', 'performanceFees'],
          triggers: ['fee', 'afg', 'asset fee grid', 'management fee', 'pricing']
        },
        'returns': {
          method: 'createAnnualizedReturnTable',
          description: 'Strategy performance returns',
          requiredData: ['strategies', 'ytd', 'oneYear', 'threeYear', 'fiveYear'],
          triggers: ['returns', 'performance', 'annualized', 'strategy performance']
        },
        'attribution': {
          method: 'createAttributionTable',
          description: 'Performance attribution analysis',
          requiredData: ['factors', 'contributions', 'weights'],
          triggers: ['attribution', 'factor analysis', 'contribution', 'breakdown']
        },
        'risk-metrics': {
          method: 'createRiskMetricsTable',
          description: 'Risk analysis metrics',
          requiredData: ['metrics', 'portfolio', 'benchmark', 'relative'],
          triggers: ['risk', 'volatility', 'drawdown', 'beta', 'var', 'metrics']
        }
      },

      // Visual infographic assets (converted from Adobe Illustrator)
      infographics: {
        'firm-structure': {
          method: 'createFirmStructureInfographic',
          description: 'Network diagram of firm capabilities',
          requiredData: [],
          triggers: ['firm structure', 'organization', 'capabilities', 'services', 'network']
        },
        'process-flow': {
          method: 'createInvestmentProcessFlow',
          description: 'Investment methodology workflow',
          requiredData: [],
          triggers: ['process', 'methodology', 'workflow', 'investment process', 'approach']
        },
        'ocio-triangle': {
          method: 'createOCIOTriangle',
          description: 'OCIO service model visualization',
          requiredData: [],
          triggers: ['ocio', 'outsourced cio', 'triangle', 'investment officer']
        },
        'communication-flow': {
          method: 'createCommunicationFlow',
          description: 'Communication network diagram',
          requiredData: [],
          triggers: ['communication', 'collaboration', 'network', 'client flow']
        },
        'strategy-performance': {
          method: 'createStrategyPerformanceViz',
          description: 'Bull/Bear market performance visualization',
          requiredData: ['bullMarket', 'bearMarket', 'benchmark'],
          triggers: ['bull bear', 'market performance', 'bull market', 'bear market']
        }
      }
    };
  }

  /**
   * Smart Asset Detection and Integration
   * Automatically detects which assets to use based on content
   */
  detectAndAddAssets(slide, slideData) {
    console.log('🤖 Analyzing content for appropriate assets...');
    
    const contentText = this.extractAllText(slideData).toLowerCase();
    const detectedAssets = [];
    
    // Check for data table opportunities
    Object.entries(this.assetRegistry.dataTables).forEach(([key, asset]) => {
      const triggerScore = asset.triggers.filter(trigger => 
        contentText.includes(trigger.toLowerCase())
      ).length;
      
      if (triggerScore > 0) {
        detectedAssets.push({
          type: 'dataTable',
          key,
          asset,
          confidence: triggerScore * 0.3,
          reason: `Found ${triggerScore} trigger(s) for ${asset.description}`
        });
      }
    });
    
    // Check for infographic opportunities
    Object.entries(this.assetRegistry.infographics).forEach(([key, asset]) => {
      const triggerScore = asset.triggers.filter(trigger => 
        contentText.includes(trigger.toLowerCase())
      ).length;
      
      if (triggerScore > 0) {
        detectedAssets.push({
          type: 'infographic',
          key,
          asset,
          confidence: triggerScore * 0.4,
          reason: `Found ${triggerScore} trigger(s) for ${asset.description}`
        });
      }
    });
    
    // Sort by confidence and apply best match
    detectedAssets.sort((a, b) => b.confidence - a.confidence);
    
    if (detectedAssets.length > 0) {
      const bestAsset = detectedAssets[0];
      console.log(`🎯 Selected Asset: ${bestAsset.asset.description} (confidence: ${Math.round(bestAsset.confidence * 100)}%)`);
      console.log(`   Reason: ${bestAsset.reason}`);
      
      this.applyAsset(slide, slideData, bestAsset);
      return bestAsset;
    }
    
    console.log('ℹ️  No specific assets detected, using standard template');
    return null;
  }

  /**
   * Apply detected asset to slide
   */
  applyAsset(slide, slideData, assetInfo) {
    const { type, key, asset } = assetInfo;
    
    try {
      if (type === 'dataTable') {
        // Apply data table asset
        const tableMethod = this.tables[asset.method];
        if (tableMethod) {
          tableMethod.call(this.tables, slide, slideData.tableData);
        }
      } else if (type === 'infographic') {
        // Apply infographic asset
        const visualMethod = this.visuals[asset.method];
        if (visualMethod) {
          visualMethod.call(this.visuals, slide, slideData.data || slideData.visualConfig || {});
        }
      }
      
      console.log(`✅ Successfully applied ${asset.description}`);
    } catch (error) {
      console.error(`❌ Error applying asset ${key}:`, error.message);
      // Fallback to standard template
      this.templates.createContentSlide(slideData.title, slideData.content || 'Asset generation error');
    }
  }

  /**
   * Create Enhanced Data Slide with Asset Integration
   * Automatically selects and integrates appropriate data visualization
   */
  createDataSlideWithAssets(slideData) {
    console.log('📊 Creating enhanced data slide with asset integration...');
    
    const slide = this.pptx.addSlide();
    
    // Set background
    slide.background = { color: _c(POTOMAC_COLORS.PRIMARY.WHITE) };

    // Add logo
    this.templates.addLogo(slide, { x: 8.8, y: 0.3, w: 1, h: 0.4 });

    // Add title
    slide.addText((slideData.title || 'DATA ANALYSIS').toUpperCase(), {
      x: 0.5, y: 0.5, w: 8, h: 1,
      fontFace: POTOMAC_FONTS.HEADERS.family,
      fontSize: 30,
      color: _c(POTOMAC_COLORS.PRIMARY.DARK_GRAY),
      bold: true,
    });

    // Title underline — FIX: was this.pptx.shapes.RECTANGLE (deprecated v2 API)
    slide.addShape(this.pptx.ShapeType.rect, {
      x: 0.5, y: 1.4, w: 2, h: 0.05,
      fill: { color: _c(POTOMAC_COLORS.PRIMARY.YELLOW) },
      line: { color: _c(POTOMAC_COLORS.PRIMARY.YELLOW), width: 0 },
    });
    
    // Detect and apply appropriate asset
    const appliedAsset = this.detectAndAddAssets(slide, slideData);
    
    // If no asset was applied, add standard content
    if (!appliedAsset && slideData.content) {
      slide.addText(slideData.content, {
        x: 0.5, y: 2.2, w: 9, h: 3,
        fontFace: POTOMAC_FONTS.BODY.family, fontSize: 16,
        color: _c(POTOMAC_COLORS.PRIMARY.DARK_GRAY),
        lineSpacing: 24,
      });
    }
    
    return slide;
  }

  /**
   * Create Enhanced Process Slide with Visual Flow
   * Integrates process infographics automatically
   */
  createProcessSlideWithAssets(slideData) {
    console.log('🔄 Creating enhanced process slide with visual assets...');
    
    const slide = this.pptx.addSlide();
    
    // Set background
    slide.background = { color: _c(POTOMAC_COLORS.PRIMARY.WHITE) };

    // Add logo
    this.templates.addLogo(slide, { x: 8.8, y: 0.3, w: 1, h: 0.4 });

    // Detect process-related content and apply visual elements
    const appliedAsset = this.detectAndAddAssets(slide, slideData);
    
    // If no specific process asset detected, use enhanced template
    if (!appliedAsset) {
      return this.templates.createProcessSlide(slideData.title, slideData.steps || slideData.content, slideData.options);
    }
    
    return slide;
  }

  /**
   * Create Strategy Showcase Slide
   * Combines multiple assets for comprehensive strategy presentation
   */
  createStrategyShowcase(slideData) {
    console.log('🎯 Creating comprehensive strategy showcase...');
    
    const slide = this.pptx.addSlide();
    
    // Background
    slide.background = { color: _c(POTOMAC_COLORS.PRIMARY.WHITE) };

    // Logo
    this.templates.addLogo(slide, { x: 8.8, y: 0.3, w: 1, h: 0.4 });

    // Strategy title  — FIX: removed fontWeight:'bold' (pptxgenjs ignores it), fixed _c()
    slide.addText((slideData.title || 'STRATEGY OVERVIEW').toUpperCase(), {
      x: 0.5, y: 0.5, w: 8, h: 1,
      fontFace: POTOMAC_FONTS.HEADERS.family,
      fontSize: 28,
      color: _c(POTOMAC_COLORS.PRIMARY.DARK_GRAY),
      bold: true,
    });
    
    // If strategy performance data is available, create performance visualization
    if (slideData.performanceData) {
      this.visuals.createStrategyPerformanceViz(slide, slideData.performanceData, {
        startX: 0.5,
        startY: 1.8,
        width: 9,
        height: 3.5
      });
    } else {
      // Standard content with visual enhancement
      return this.templates.createTwoColumnSlide(
        slideData.title,
        slideData.leftContent || slideData.content,
        slideData.rightContent || 'Strategy Benefits:\n\n• Risk-adjusted returns\n• Systematic approach\n• Proven methodology\n• '
      );
    }
    
    return slide;
  }

  // =======================
  // ASSET UTILITY METHODS
  // =======================

  extractAllText(slideData) {
    let text = '';
    if (slideData.title) text += slideData.title + ' ';
    if (slideData.subtitle) text += slideData.subtitle + ' ';
    if (slideData.content) {
      if (Array.isArray(slideData.content)) {
        text += slideData.content.join(' ') + ' ';
      } else {
        text += slideData.content + ' ';
      }
    }
    if (slideData.leftContent) text += slideData.leftContent + ' ';
    if (slideData.rightContent) text += slideData.rightContent + ' ';
    if (slideData.description) text += slideData.description + ' ';
    return text;
  }

  /**
   * Get Available Assets Summary
   * Returns metadata about all available converted assets
   */
  getAvailableAssets() {
    const summary = {
      dataTables: Object.keys(this.assetRegistry.dataTables).length,
      infographics: Object.keys(this.assetRegistry.infographics).length,
      total: Object.keys(this.assetRegistry.dataTables).length + Object.keys(this.assetRegistry.infographics).length,
      
      details: {
        dataTables: Object.entries(this.assetRegistry.dataTables).map(([key, asset]) => ({
          key,
          name: asset.description,
          triggers: asset.triggers.join(', ')
        })),
        infographics: Object.entries(this.assetRegistry.infographics).map(([key, asset]) => ({
          key,
          name: asset.description,
          triggers: asset.triggers.join(', ')
        }))
      }
    };
    
    return summary;
  }

  /**
   * Manual Asset Application
   * Directly apply specific assets when automatic detection isn't sufficient
   */
  applySpecificAsset(slide, assetType, assetKey, data = {}, config = {}) {
    console.log(`🎯 Manually applying asset: ${assetType}/${assetKey}`);
    
    if (assetType === 'dataTable') {
      const asset = this.assetRegistry.dataTables[assetKey];
      if (asset) {
        const method = this.tables[asset.method];
        if (method) {
          return method.call(this.tables, slide, data, config.position);
        }
      }
    } else if (assetType === 'infographic') {
      const asset = this.assetRegistry.infographics[assetKey];
      if (asset) {
        const method = this.visuals[asset.method];
        if (method) {
          return method.call(this.visuals, slide, data, config);
        }
      }
    }
    
    console.warn(`⚠️ Asset ${assetType}/${assetKey} not found or method unavailable`);
    return slide;
  }
}

/**
 * Enhanced Presentation Builder with Full Asset Integration
 * Extends the Phase 2 builder with Phase 3 asset capabilities
 */
class PotomacAssetIntegratedBuilder {
  constructor(options = {}) {
    const pptxgen = require("pptxgenjs");
    this.pres = new pptxgen();
    this.options = {
      title: options.title || 'POTOMAC PRESENTATION',
      subtitle: options.subtitle || '',
      author: 'Potomac',
      company: 'Potomac',
      palette: options.palette || 'STANDARD',
      presentationType: options.type || 'general',
      strictCompliance: options.strictCompliance !== false,
      ...options
    };
    
    this.setupPresentation();
    this.assets = new PotomacIntegratedAssets(this.pres, this.options);
    this.slideStack = [];
  }

  setupPresentation() {
    this.pres.author   = this.options.author;
    this.pres.company  = this.options.company;
    this.pres.revision = '1';
    this.pres.subject  = this.options.title;
    this.pres.title    = this.options.title;
    // FIX: was defineLayout({width:13.333}) — wrong! All coordinates assume 10" width.
    // LAYOUT_16x9 is the correct pptxgenjs name for the standard 10"×7.5" slide.
    this.pres.layout   = 'LAYOUT_16x9';
  }

  /**
   * Add Enhanced Slide with Full Asset Integration
   * Combines Phase 2 smart templates with Phase 3 converted assets
   */
  addSlide(slideData) {
    console.log(`🎨 Creating enhanced slide with asset integration: ${slideData.title}`);
    
    // First check for specific asset requests
    if (slideData.assetType && slideData.assetKey) {
      const slide = this.pres.addSlide();
      return this.assets.applySpecificAsset(slide, slideData.assetType, slideData.assetKey, slideData.data, slideData.config);
    }
    
    // Check for data-heavy content that needs table assets
    const hasDataContent = this.hasDataContent(slideData);
    const hasProcessContent = this.hasProcessContent(slideData);
    
    if (hasDataContent) {
      return this.assets.createDataSlideWithAssets(slideData);
    } else if (hasProcessContent) {
      return this.assets.createProcessSlideWithAssets(slideData);
    } else {
      // Use Phase 2 smart template selection
      return this.assets.templates.createContentSlide(slideData.title, slideData.content);
    }
  }

  /**
   * Generate Complete Research Presentation with Assets
   * Enhanced version of Phase 2 research generator with converted assets
   */
  generateEnhancedResearchPresentation(data) {
    console.log('📊 Generating Enhanced Research Presentation with Integrated Assets...');
    
    // Title slide
    this.addSlide({
      title: data.title || this.options.title,
      subtitle: data.subtitle || 'Investment Research & Analysis',
      role: 'title',
      isFirst: true
    });
    
    // Executive Summary
    this.addSlide({
      title: 'Executive Summary',
      content: data.executiveSummary || [
        'Market conditions remain challenging with elevated volatility',
        'Active management opportunities emerging in select sectors',
        'Risk management paramount given uncertain environment',
        'Strategic positioning recommended for optimal outcomes'
      ]
    });
    
    // Performance Analysis with Data Table Asset
    this.addSlide({
      title: 'Performance Analysis',
      assetType: 'dataTable',
      assetKey: 'passive-active',
      data: data.performanceData
    });
    
    // Strategy Returns with Asset Integration
    this.addSlide({
      title: 'Strategy Performance',
      assetType: 'dataTable',
      assetKey: 'returns',
      data: data.strategyReturns
    });
    
    // Investment Process with Visual Asset
    this.addSlide({
      title: 'Our Investment Process',
      assetType: 'infographic',
      assetKey: 'process-flow',
      config: data.processConfig || {}
    });
    
    // Risk Analysis with Table Asset
    this.addSlide({
      title: 'Risk Metrics',
      assetType: 'dataTable',
      assetKey: 'risk-metrics',
      data: data.riskData
    });
    
    // Closing with Call-to-Action
    this.addSlide({
      title: 'Questions & Discussion',
      role: 'cta',
      isClosing: true,
      actionText: 'Ready to discuss how these insights can enhance your portfolio?',
      contactInfo: 'potomac.com | (305) 824-2702 | info@potomac.com'
    });
    
    return this;
  }

  // =======================
  // CONTENT ANALYSIS HELPERS
  // =======================

  hasDataContent(slideData) {
    const text = this.assets.extractAllText(slideData).toLowerCase();
    const dataKeywords = ['performance', 'returns', 'data', 'metrics', 'statistics', 'analysis', 'comparison', 'fee', 'attribution'];
    return dataKeywords.some(keyword => text.includes(keyword)) || 
           slideData.tableData || 
           slideData.performanceData ||
           slideData.riskData;
  }

  hasProcessContent(slideData) {
    const text = this.assets.extractAllText(slideData).toLowerCase();
    const processKeywords = ['process', 'workflow', 'methodology', 'approach', 'steps', 'procedure'];
    return processKeywords.some(keyword => text.includes(keyword)) || 
           slideData.steps ||
           slideData.processFlow;
  }

  /**
   * Save with Asset Usage Report
   */
  async save(filename) {
    const path = require('path');
    const fs = require('fs');
    
    const outputPath = path.join(__dirname, '../examples/', filename);
    
    // Ensure examples directory exists
    const examplesDir = path.dirname(outputPath);
    if (!fs.existsSync(examplesDir)) {
      fs.mkdirSync(examplesDir, { recursive: true });
    }
    
    try {
      await this.pres.writeFile({ fileName: outputPath });
      
      // Generate asset usage report
      const assetSummary = this.assets.getAvailableAssets();
      console.log(`📄 Presentation saved: ${outputPath}`);
      console.log(`📊 Available Assets: ${assetSummary.total} (${assetSummary.dataTables} tables, ${assetSummary.infographics} infographics)`);
      
      return outputPath;
    } catch (error) {
      console.error('❌ Failed to save presentation with assets:', error.message);
      throw error;
    }
  }
}

module.exports = {
  PotomacIntegratedAssets,
  PotomacAssetIntegratedBuilder
};